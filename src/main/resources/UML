class User {
  +id: Long
  +nome: String
  +email: String
  +telefone: String
}

class Colaborador {
  +id: Long
  +nome: String
  +email: String
  +telefone: String
}

class Carro {
  +id: Long
  +marca: String
  +modelo: String
  +matricula: String
  +motorista: Colaborador
  +kilometragem: Double
  +despesas: List<Despesa>
}

abstract class Despesa {
  +id: Long
  +nome: String
  +descricao: String
  +valor: Double
  +data: Instant
}

interface Pagamento {
  +processarPagamento(): void
}

class DespesaCombustivel {
  +quantidade: int
  +unidade: String // Litros, KWH, Minutos
  +numeroCartao: String
}

class DespesaPortagem {
  +numeroContrato: String
  +numeroAparelho: String
  +matricula: String
}

class PagamentoSemanal {
  +id: Long
  +motorista: Utilizador
  +valor: Double
  +dataPagamento: LocalDateTime
}

class PlataformaPagamento {
  +id: Long
  +pagamentoSemanal: PagamentoSemanal
  +plataforma: Plataforma
  +gorjetas: Double
}

enum Plataforma {
  UBER
  BOLT
  OUTRA
}

User <|-- Colaborador
Colaborador --* Carro : possui
Carro --* Despesa : tem
Despesa <|-- DespesaCombustivel
Despesa <|-- DespesaPortagem
Colaborador --* PagamentoSemanal : recebe
PagamentoSemanal --* PlataformaPagamento : relacionado
PlataformaPagamento --> Plataforma : usa
Pagamento <|.. PagamentoSemanal : implementa
