<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane fx:id="apPrincipal" prefHeight="533.0" prefWidth="1083.0" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/23.0.1" fx:controller="application.controllers.PagamentoController">

    <!-- FORMULÁRIO -->
    <VBox layoutX="20" layoutY="20" spacing="10">
        <children>

            <Label style="-fx-font-size: 20px; -fx-font-weight: bold;" text="Gestão de Pagamentos" />

            <HBox spacing="10">
                <children>
                    <Label alignment="TOP_RIGHT" prefWidth="120" text="Colaborador:" />
                    <ComboBox fx:id="comboBoxColaborador" prefWidth="250" />
                </children>
            </HBox>


            <HBox spacing="10">
                <children>
                    <Label alignment="TOP_RIGHT" prefWidth="120" text="Tipo Pagamento:" />
                    <ComboBox fx:id="comboBoxTipoPagamento" prefWidth="250" />
                </children>
            </HBox>

            <HBox spacing="10">
                <children>
                    <Label alignment="TOP_RIGHT" prefHeight="17.0" prefWidth="119.0" text="Plataforma:" />
                    <ComboBox fx:id="comboBoxPlataforma" prefHeight="25.0" prefWidth="251.0" />
                </children>
            </HBox>

            <HBox spacing="10">
                <children>
                    <Label alignment="TOP_RIGHT" prefWidth="120" text="Valor (€):" />
                    <TextField fx:id="txtValor" prefWidth="250" />
                </children>
            </HBox>

            <HBox spacing="10">
                <children>
                    <Label alignment="TOP_RIGHT" prefWidth="120" text="Data:" />
                    <DatePicker fx:id="datePickerData" prefWidth="250" />
                </children>
            </HBox>
      
          <!-- BOTÕES -->
          <HBox spacing="15">
              <children>
               <Label prefHeight="17.0" prefWidth="37.0" text=" " />
                  <Button fx:id="btEditar" alignment="TOP_CENTER" onAction="#onclickOnEditar" prefHeight="25.0" prefWidth="75.0" text="Editar" />
                  <Button fx:id="btEliminar" alignment="TOP_CENTER" onAction="#onclickOnEliminar" prefHeight="25.0" prefWidth="65.0" text="Eliminar" />
                  <Button fx:id="btGravar" alignment="TOP_CENTER" onAction="#onclickOnGravar" prefHeight="25.0" prefWidth="71.0" text="Gravar" />
                  <Button fx:id="btRegistar" alignment="TOP_CENTER" onAction="#onclickOnRegistar" prefHeight="25.0" prefWidth="72.0" text="Registar" />
              </children>
          </HBox>

        </children>
    </VBox>

    <!-- TABELA -->
    <TableView fx:id="tableView" layoutX="407.0" layoutY="20" prefHeight="500" prefWidth="663.0">

        <columns>

            <TableColumn fx:id="colaboradorColumn" prefWidth="150" text="Colaborador" />
            <TableColumn fx:id="cartaoColumn" prefWidth="120" text="Cartão" />
            <TableColumn fx:id="plataformaColumn" prefWidth="120" text="Plataforma" />
            <TableColumn fx:id="dataColumn" prefWidth="100" text="Data" />
            <TableColumn fx:id="valorColumn" prefWidth="80" text="Valor (€)" />
            <TableColumn fx:id="tipoColumn" prefWidth="100" text="Tipo" />

        </columns>

        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
        </columnResizePolicy>

    </TableView>

</AnchorPane>
