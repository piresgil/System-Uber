                    </children>
                </AnchorPane>
                <TableView fx:id="tableView" prefHeight="584.0" prefWidth="600.0" tableMenuButtonVisible="true">

                    <columns>
                        <TableColumn fx:id="marcaColumn" prefWidth="150" text="Marca" />
                        <TableColumn fx:id="modeloColumn" prefWidth="150" text="Modelo" />
                        <TableColumn fx:id="matriculaColumn" prefWidth="150" text="Matrícula" />
                        <TableColumn fx:id="kilometragemColumn" prefWidth="100" text="Km" />
                        <TableColumn fx:id="alugadoColumn" prefWidth="75" text="Alugado" />
                        <TableColumn fx:id="ativoColumn" prefWidth="75" text="Ativo" />
                    </columns>

                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>

                </TableView>

            </children>
