<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane fx:id="apPrincipal" cacheShape="false" centerShape="false" prefHeight="600.0" prefWidth="600.0" scaleShape="false" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="application.controllers.CarroController">
    <children>
        <VBox prefHeight="200.0" prefWidth="100.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <children>
                <AnchorPane prefHeight="55.0" prefWidth="600.0">
                    <children>
                        <Label alignment="TOP_CENTER" contentDisplay="CENTER" layoutX="-1.0" prefHeight="52.0" prefWidth="600.0" text="Carros" textAlignment="CENTER" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
                            <font>
                                <Font size="36.0" />
                            </font>
                        </Label>
                    </children>
                </AnchorPane>
                <AnchorPane>
                    <children>
                        <Label layoutX="154.0" layoutY="22.0" text="Marca" />
                        <Label layoutX="145.0" layoutY="65.0" text="Modelo" />
                        <Label layoutX="136.0" layoutY="108.0" text="Matrícula" />
                        <Label layoutX="113.0" layoutY="150.0" text="Kilometragem" />
                        <TextField fx:id="txtMarca" layoutX="200.0" layoutY="18.0" AnchorPane.leftAnchor="200.0" AnchorPane.rightAnchor="100.0" />
                        <TextField fx:id="txtModelo" layoutX="200.0" layoutY="61.0" AnchorPane.leftAnchor="200.0" AnchorPane.rightAnchor="100.0" />
                        <TextField fx:id="txtMatricula" layoutX="200.0" layoutY="104.0" AnchorPane.leftAnchor="200.0" AnchorPane.rightAnchor="100.0" />
                        <TextField fx:id="txtKilometragem" layoutX="200.0" layoutY="146.0" AnchorPane.leftAnchor="200.0" AnchorPane.rightAnchor="100.0" />
                        <Button fx:id="btRegistar" layoutX="441.0" layoutY="182.0" mnemonicParsing="false" onAction="#onclickOnRegistar" text="Registar" textAlignment="CENTER" AnchorPane.bottomAnchor="10.0" AnchorPane.rightAnchor="100.0" AnchorPane.topAnchor="180.0" />
                        <Button fx:id="btEditar" disable="true" layoutX="200.0" layoutY="150.0" mnemonicParsing="false" onAction="#onclickOnEditar" text="Editar" textAlignment="CENTER" AnchorPane.bottomAnchor="10.0" AnchorPane.leftAnchor="200.0" AnchorPane.topAnchor="180.0" />
                        <Button fx:id="btGravar" layoutX="441.0" layoutY="233.0" mnemonicParsing="false" onAction="#onclickOnGravar" text="Gravar" textAlignment="CENTER" AnchorPane.bottomAnchor="10.0" AnchorPane.leftAnchor="313.0" AnchorPane.topAnchor="180.0" />
                        <Button fx:id="btEliminar" layoutX="253.0" layoutY="183.0" mnemonicParsing="false" onAction="#onclickOnEliminar" text="Eliminar" textAlignment="CENTER" AnchorPane.bottomAnchor="10.0" AnchorPane.leftAnchor="250.0" AnchorPane.topAnchor="180.0" />
