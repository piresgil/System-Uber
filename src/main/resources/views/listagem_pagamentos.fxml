<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<AnchorPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="application.controllers.ListagemPagamentosController"
            prefWidth="1100" prefHeight="650">

    <!-- FILTROS -->
    <VBox spacing="10" layoutX="20" layoutY="20" prefWidth="1060">
        <children>

            <Label text="Listagem de Pagamentos"
                   style="-fx-font-size: 22px; -fx-font-weight: bold;"/>

            <!-- Linha 1: Pesquisa global -->
            <HBox spacing="10">
                <children>
                    <Label text="Pesquisar:" prefWidth="100"/>
                    <TextField fx:id="txtPesquisa" prefWidth="300"
                               promptText="Pesquisar por qualquer campo..."/>
                </children>
            </HBox>

            <!-- Linha 2: Datas -->
            <HBox spacing="10">
                <children>
                    <Label text="Data início:" prefWidth="100"/>
                    <DatePicker fx:id="dpInicio" prefWidth="150"/>

                    <Label text="Data fim:" prefWidth="100"/>
                    <DatePicker fx:id="dpFim" prefWidth="150"/>
                </children>
            </HBox>

            <!-- Linha 3: Plataforma e Tipo -->
            <HBox spacing="10">
                <children>
                    <Label text="Plataforma:" prefWidth="100"/>
                    <ComboBox fx:id="comboPlataforma" prefWidth="200"/>

                    <Label text="Tipo:" prefWidth="100"/>
                    <ComboBox fx:id="comboTipo" prefWidth="200"/>

                    <Button text="Limpar Filtros"
                            onAction="#onclickLimpar"
                            prefWidth="150"/>
                </children>
            </HBox>

        </children>
    </VBox>

    <!-- TABELA -->
    <TableView fx:id="tableView"
               layoutX="20" layoutY="180"
               prefWidth="1060" prefHeight="440">

        <columns>

            <TableColumn fx:id="colColaborador"
                         text="Colaborador" prefWidth="200"/>

            <TableColumn fx:id="colPlataforma"
                         text="Plataforma" prefWidth="150"/>

            <TableColumn fx:id="colTipo"
                         text="Tipo" prefWidth="150"/>

            <TableColumn fx:id="colData"
                         text="Data" prefWidth="150"/>

            <TableColumn fx:id="colValor"
                         text="Valor (€)" prefWidth="150"/>

        </columns>

        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
        </columnResizePolicy>

        <HBox spacing="20" layoutX="20" layoutY="630">
            <children>
                <Label fx:id="lblTotal" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
                <Label fx:id="lblTotalPlataforma"/>
                <Label fx:id="lblTotalTipo"/>
            </children>
        </HBox>


    </TableView>
    <HBox spacing="10">
        <children>
            <Button text="Exportar CSV" onAction="#onclickExportarCSV" prefWidth="150"/>
            <Button text="Exportar Excel" onAction="#onclickExportarExcel" prefWidth="150"/>
            <Button text="Importar Excel" onAction="#onclickImportarExcel" prefWidth="150"/>

        </children>
    </HBox>


</AnchorPane>
