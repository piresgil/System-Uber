<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane fx:id="apPrincipal" cacheShape="false" centerShape="false" prefHeight="600.0" prefWidth="600.0"
            scaleShape="false" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="application.controllers.UserController">
    <children>
        <VBox prefHeight="200.0" prefWidth="100.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0"
              AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <children>
                <AnchorPane prefHeight="55.0" prefWidth="600.0">
                    <children>
                        <Label alignment="TOP_CENTER" contentDisplay="CENTER" layoutX="-1.0" prefHeight="52.0"
                               prefWidth="600.0" text="Utilizadores" textAlignment="CENTER"
                               AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0"
                               AnchorPane.topAnchor="0.0">
                            <font>
                                <Font size="36.0"/>
                            </font>
                        </Label>
                    </children>
                </AnchorPane>
                <AnchorPane prefHeight="204.0" prefWidth="600.0">
                    <children>
                        <Label layoutX="152.0" layoutY="21.0" text="Nome" textAlignment="CENTER"
                               AnchorPane.leftAnchor="152.0"/>
                        <Label layoutX="151.0" layoutY="66.0" text="E-mail" textAlignment="CENTER"
                               AnchorPane.leftAnchor="151.0"/>
                        <Label layoutX="135.0" layoutY="106.0" text="Password" textAlignment="CENTER"
                               AnchorPane.leftAnchor="135.0"/>
                        <TextField fx:id="txtNome" layoutX="121.0" layoutY="18.0"
                                   AnchorPane.leftAnchor="200.0" AnchorPane.rightAnchor="100.0"/>
                        <TextField  fx:id="txtEmail" layoutX="121.0" layoutY="61.0"
                                   AnchorPane.leftAnchor="200.0" AnchorPane.rightAnchor="100.0"/>
                        <TextField id="txtPass" fx:id="txtPassword" layoutX="200.0" layoutY="104.0"
                                   AnchorPane.leftAnchor="200.0" AnchorPane.rightAnchor="100.0"/>
                        <Button fx:id="btRegistar" layoutX="441.0" layoutY="128.0"
                                mnemonicParsing="false" onAction="#onclickOnRegistar" text="Registar"
                                textAlignment="CENTER" AnchorPane.bottomAnchor="10.0" AnchorPane.rightAnchor="100.0"
                                AnchorPane.topAnchor="150.0"/>
                        <Button  fx:id="btEditar" layoutX="199.0" layoutY="150.0"
                                mnemonicParsing="false" onAction="#onclickOnEditar" text="Editar" textAlignment="CENTER"
                                AnchorPane.bottomAnchor="10.0" AnchorPane.leftAnchor="200.0"
                                AnchorPane.topAnchor="150.0"/>
                        <Button fx:id="btGravar" layoutX="313.0" layoutY="150.0" mnemonicParsing="false"
                                onAction="#onclickOnGravar" text="Gravar" textAlignment="CENTER"
                                AnchorPane.bottomAnchor="10.0" AnchorPane.leftAnchor="313.0"
                                AnchorPane.topAnchor="150.0"/>
                        <Button  fx:id="btEliminar" layoutX="253.0" layoutY="150.0"
                                mnemonicParsing="false" onAction="#onclickOnEliminar" text="Eliminar"
                                textAlignment="CENTER" AnchorPane.bottomAnchor="10.0" AnchorPane.leftAnchor="250.0"
                                AnchorPane.topAnchor="150.0"/>
                    </children>
                </AnchorPane>
                <TableView fx:id="tableView" cacheShape="false" editable="true" focusTraversable="false"
                           prefHeight="584.0" prefWidth="600.0" tableMenuButtonVisible="true">

                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                    </columnResizePolicy>
                </TableView>
            </children>
        </VBox>
    </children>
    <cursor>
        <Cursor fx:constant="HAND"/>
    </cursor>
</AnchorPane>
