<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane fx:id="apPrincipal" cacheShape="false" centerShape="false" prefHeight="600.0" prefWidth="600.0" scaleShape="false" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="application.controllers.ColaboradorController">
    <children>
        <VBox prefHeight="200.0" prefWidth="100.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <children>
                <AnchorPane prefHeight="55.0" prefWidth="600.0">
                    <children>
                        <Label alignment="TOP_CENTER" contentDisplay="CENTER" layoutX="-1.0" prefHeight="52.0" prefWidth="600.0" text="Colaboradores" textAlignment="CENTER" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
                            <font>
                                <Font size="36.0" />
                            </font>
                        </Label>
                    </children>
                </AnchorPane>
                <AnchorPane prefHeight="449.0" prefWidth="600.0">
                    <children>
                        <Label layoutX="152.0" layoutY="21.0" text="Nome" />
                        <Label layoutX="151.0" layoutY="66.0" text="E-mail" />
                        <Label layoutX="140.0" layoutY="106.0" text="Telefone" />

                        <TextField fx:id="txtNome" layoutX="200.0" layoutY="17.0" prefHeight="25.0" prefWidth="299.0" />
                        <TextField fx:id="txtEmail" layoutX="200.0" layoutY="62.0" prefHeight="25.0" prefWidth="299.0" />
                        <TextField fx:id="txtTelefone" layoutX="200.0" layoutY="102.0" prefHeight="25.0" prefWidth="299.0" />

                        <!-- NOVO CAMPO: Tipo -->
                        <Label layoutX="162.0" layoutY="146.0" text="Tipo" />
                        <ComboBox fx:id="cbTipo" layoutX="200.0" layoutY="142.0" prefHeight="25.0" prefWidth="299.0" AnchorPane.leftAnchor="200.0" AnchorPane.rightAnchor="101.0" />

                        <Button fx:id="btRegistar" layoutX="441.0" layoutY="175.0" mnemonicParsing="false" onAction="#onclickOnRegistar" text="Registar" />

                        <Button fx:id="btEditar" disable="true" layoutX="200.0" layoutY="175.0" mnemonicParsing="false" onAction="#onclickOnEditar" text="Editar" />

                        <Button fx:id="btGravar" layoutX="324.0" layoutY="175.0" mnemonicParsing="false" onAction="#onclickOnGravar" text="Gravar" />

                        <Button fx:id="btEliminar" layoutX="253.0" layoutY="175.0" mnemonicParsing="false" onAction="#onclickOnEliminar" text="Eliminar" />
                    </children>
                </AnchorPane>

                <TableView fx:id="tableView" prefHeight="584.0" prefWidth="600.0" tableMenuButtonVisible="true">

                    <columns>
                        <TableColumn fx:id="nomeColumn" prefWidth="150" text="Nome" />
                        <TableColumn fx:id="emailColumn" prefWidth="150" text="Email" />
                        <TableColumn fx:id="telefoneColumn" prefWidth="150" text="Telefone" />
                        <TableColumn fx:id="tipoColumn" prefWidth="150" text="Tipo" />
                    </columns>

                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>

                </TableView>

            </children>
        </VBox>
    </children>
    <cursor>
        <Cursor fx:constant="HAND" />
    </cursor>
</AnchorPane>
